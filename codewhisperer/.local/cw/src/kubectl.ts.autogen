        },
        { name: ["--quiet", "-q"],
          description: "If true, suppress informational messages.",
        },
        { name: ["--replace"],
          description: "When used with '--copy-to', delete the original Pod.",
        },
        { name: ["--same-node"],
          description:
            "When used with '--copy-to', schedule the copy of target Pod on the same node.",
