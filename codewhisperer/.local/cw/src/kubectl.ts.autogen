          args: [{ name: "set-image" }],
        },
        { name: ["--share-processes"],
          description:
            "When used with '--copy-to', enable process namespace sharing in the copy.",
        },
        { name: ["--stdin", "-i"],
          description:
            "Keep stdin open on the container(s) in the pod, even if nothing is attached.",
