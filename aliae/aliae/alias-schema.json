{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "$defs": {
    "include_tag": {
      "type": "string",
      "pattern": "^\\!include(_dir)?\\s+.*$"
    }
  },
  "properties": {
    "alias": {
      "oneOf": [
        {
          "$ref": "#/$defs/include_tag"
        },
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      ],
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
